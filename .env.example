# Copy to .env.local and fill in real values. Never commit .env.local —
# it is already covered by .gitignore.

# --- Supabase (Phase 4 §1-§7) -----------------------------------------------
# Project Settings → API in the Supabase dashboard. Supabase's current key
# naming: "Publishable key" (sb_publishable_...) is the public, RLS-scoped
# key — the direct successor to the old "anon key" naming.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only secret key. Never prefix with NEXT_PUBLIC_, never reference
# from a Client Component — used solely by src/server/edge-functions
# (Phase 4 §8, §13).
SUPABASE_SECRET_KEY=

# --- Transactional email (Phase 4 §2, §16) ----------------------------------
RESEND_API_KEY=

# --- Product analytics (Phase 4 §15) ----------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Error & performance monitoring (Phase 4 §14) ---------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Rate limiting (Phase 4 §13, Upstash Redis) ------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
