# Copy to .env.local and fill in real values. Never commit .env.local —
# it is already covered by .gitignore.

# --- Supabase (Phase 4 §1-§7) -----------------------------------------------
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never prefix with NEXT_PUBLIC_, never reference from a
# Client Component — used solely by src/server/edge-functions (Phase 4 §8, §13).
SUPABASE_SERVICE_ROLE_KEY=

# --- Customer phone-OTP delivery (supabase/config.toml auth.sms.twilio) ----
# Read by the Supabase Auth service itself (via `supabase secrets set` on a
# hosted project), not by this Next.js app directly — listed here so every
# credential this repo depends on lives in one place.
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=

# --- Transactional email (Phase 4 §2, §16) ----------------------------------
RESEND_API_KEY=

# --- Product analytics (Phase 4 §15) ----------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Error & performance monitoring (Phase 4 §14) ---------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Rate limiting (Phase 4 §13, Upstash Redis) ------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
